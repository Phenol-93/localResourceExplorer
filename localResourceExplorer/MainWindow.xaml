<Window x:Class="LocalResourceExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helpers="clr-namespace:LocalResourceExplorer.Helpers"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LocalResourceExplorer"
        Icon="Assets/AppIcon.ico"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="600"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:DurationDisplayConverter x:Key="DurationDisplayConverter" />
        <helpers:FileSizeDisplayConverter x:Key="FileSizeDisplayConverter" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavButtonBorder" Property="Background" Value="{DynamicResource NavHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AiButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AiSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AiBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AiTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Margin="3,1"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="{DynamicResource NavHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="LocalResourceExplorer"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="本地资源登记库"
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="360"
                        Height="36"
                        Margin="32,0,16,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderStrongBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="12,8"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource SecondaryTextBrush}"
                             CaretBrush="{DynamicResource AccentBrush}"
                             VerticalContentAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Grid>
                        <Button x:Name="AddResourceButton"
                                Content="添加资源"
                                Command="{Binding ToggleAddResourceMenuCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" />
                        <Popup IsOpen="{Binding IsAddResourceMenuOpen, Mode=TwoWay}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=AddResourceButton}"
                               StaysOpen="False">
                            <Border MinWidth="132"
                                    Margin="0,6,0,0"
                                    Padding="6"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderStrongBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Button Content="选择文件"
                                            Command="{Binding AddFilesCommand}"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="选择文件夹"
                                            Command="{Binding AddFolderCommand}"
                                            Style="{StaticResource NavButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Grid>
                        <Button x:Name="SortButton"
                                Content="{Binding SortButtonText}"
                                Command="{Binding ToggleSortMenuCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" />
                        <Popup IsOpen="{Binding IsSortMenuOpen, Mode=TwoWay}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=SortButton}"
                               StaysOpen="False">
                            <Border MinWidth="150"
                                    Margin="0,6,0,0"
                                    Padding="6"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderStrongBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Button Content="名称"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="title"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="文件大小"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="size_bytes"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="修改时间"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="modified_at"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="导入时间"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="imported_at"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="音视频时长"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="duration_ms"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="上次打开时间"
                                            Command="{Binding SortByCommand}"
                                            CommandParameter="last_opened_at"
                                            Style="{StaticResource NavButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Grid>
                        <Button x:Name="ExportButton"
                                Content="导出/备份"
                                Command="{Binding ToggleExportMenuCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" />
                        <Popup IsOpen="{Binding IsExportMenuOpen, Mode=TwoWay}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=ExportButton}"
                               StaysOpen="False">
                            <Border MinWidth="180"
                                    Margin="0,6,0,0"
                                    Padding="6"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderStrongBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <Button Content="导出当前列表为 CSV"
                                            Command="{Binding ExportCurrentResourcesToCsvCommand}"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="导出当前列表为 JSON"
                                            Command="{Binding ExportCurrentResourcesToJsonCommand}"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Separator Margin="6" />
                                    <Button Content="备份数据库"
                                            Command="{Binding BackupDatabaseCommand}"
                                            Style="{StaticResource NavButtonStyle}" />
                                    <Button Content="从备份恢复数据库"
                                            Command="{Binding RestoreDatabaseFromBackupCommand}"
                                            Style="{StaticResource NavButtonStyle}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button Content="视图"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="AI 辅助整理"
                            Command="{Binding RequestAiSuggestionsCommand}"
                            Style="{StaticResource AiButtonStyle}" />
                    <Button Content="{Binding ThemeButtonText}"
                            Command="{Binding ToggleThemeCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="设置"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,18">
                        <TextBlock Text="导航"
                                   Style="{StaticResource PanelTitleStyle}"
                                   Margin="0,0,0,8" />
                        <Button Content="全部资源"
                                Command="{Binding ShowAllResourcesCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Background="{DynamicResource NavSelectedBrush}"
                                FontWeight="SemiBold" />
                        <Button Content="未整理"
                                Command="{Binding ShowUnorganizedCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="星标"
                                Command="{Binding ShowFavoritesCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="最近添加"
                                Command="{Binding ShowRecentAddedCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="最近打开"
                                Command="{Binding ShowRecentOpenedCommand}"
                                Style="{StaticResource NavButtonStyle}" />

                        <TextBlock Text="集合"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Collections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            Command="{Binding DataContext.SelectCollectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource NavButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="重命名集合"
                                                          Command="{Binding PlacementTarget.Tag.RenameCollectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="删除集合"
                                                          Command="{Binding PlacementTarget.Tag.DeleteCollectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ 新建集合"
                                Command="{Binding CreateCollectionCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Foreground="{DynamicResource AccentBrush}" />

                        <TextBlock Text="{Binding Tags.Count, StringFormat=标签（{0}）}"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Tags}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource NavButtonStyle}"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                        <Button.Content>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding ResourceCount}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           FontSize="12" />
                                                <Border Margin="0,0,8,0"
                                                        Padding="8,3"
                                                        Background="{Binding Color}"
                                                        CornerRadius="10">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource TagTextBrush}"
                                                               FontSize="12" />
                                                </Border>
                                            </DockPanel>
                                        </Button.Content>
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="修改标签颜色"
                                                          Command="{Binding PlacementTarget.Tag.ChangeTagColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="删除标签"
                                                          Command="{Binding PlacementTarget.Tag.DeleteTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ 新建标签"
                                Command="{Binding CreateTagCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Foreground="{DynamicResource AccentBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Margin="18"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ViewTitle}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                            <TextBlock Text="SQLite 资源列表"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <ListView x:Name="ResourceList"
                              Grid.Row="1"
                              Margin="10,0,10,10"
                              ItemsSource="{Binding Resources}"
                              SelectedItem="{Binding SelectedResource, Mode=TwoWay}"
                              SelectionMode="Extended"
                              SelectionChanged="ResourceList_SelectionChanged"
                              BorderThickness="0"
                              Background="Transparent"
                              Foreground="{DynamicResource SecondaryTextBrush}"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}" />
                                <Setter Property="MinHeight" Value="34" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Padding" Value="6,3" />
                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="打开文件"
                                                      Command="{Binding PlacementTarget.Tag.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="打开所在文件夹"
                                                      Command="{Binding PlacementTarget.Tag.OpenContainingFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="复制路径"
                                                      Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="加入集合..."
                                                      Command="{Binding PlacementTarget.Tag.AddResourceToCollectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="添加标签..."
                                                      Command="{Binding PlacementTarget.Tag.AddTagToResourceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="给选中资源添加标签..."
                                                      Command="{Binding PlacementTarget.Tag.AddTagToSelectedResourcesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="选中资源加入集合..."
                                                      Command="{Binding PlacementTarget.Tag.BatchAddSelectedResourcesToCollectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="选中资源移出集合..."
                                                      Command="{Binding PlacementTarget.Tag.BatchRemoveSelectedResourcesFromCollectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="选中资源添加标签..."
                                                      Command="{Binding PlacementTarget.Tag.AddTagToSelectedResourcesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="选中资源移除标签..."
                                                      Command="{Binding PlacementTarget.Tag.BatchRemoveTagFromSelectedResourcesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="批量星标"
                                                      Command="{Binding PlacementTarget.Tag.BatchSetFavoriteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="true" />
                                            <MenuItem Header="批量取消星标"
                                                      Command="{Binding PlacementTarget.Tag.BatchSetFavoriteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="false" />
                                            <Separator />
                                            <MenuItem Header="从库中移除选中记录..."
                                                      Command="{Binding PlacementTarget.Tag.BatchDeleteSelectedRecordsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListHoverBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                        <Setter Property="Opacity" Value="0.62" />
                                        <Setter Property="Background" Value="{DynamicResource MissingSurfaceBrush}" />
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="{DynamicResource ListSelectedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ListSelectedBorderBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True" />
                                            <Condition Property="IsKeyboardFocusWithin" Value="False" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="{DynamicResource ListSelectedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ListSelectedBorderBrush}" />
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="名称" Width="210" DisplayMemberBinding="{Binding OriginalName}" />
                                <GridViewColumn Header="状态" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="7,2"
                                                    Background="{DynamicResource MissingSurfaceBrush}"
                                                    BorderBrush="{DynamicResource MissingBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="9"
                                                    Visibility="{Binding IsMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="丢失"
                                                           Foreground="{DynamicResource MissingTextBrush}"
                                                           FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="扩展名" Width="80" DisplayMemberBinding="{Binding Extension}" />
                                <GridViewColumn Header="大小" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SizeBytes, Converter={StaticResource FileSizeDisplayConverter}}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="修改时间" Width="150" DisplayMemberBinding="{Binding ModifiedAt}" />
                                <GridViewColumn Header="时长" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DurationMs, Converter={StaticResource DurationDisplayConverter}}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="备注" Width="180" DisplayMemberBinding="{Binding Note}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,18">
                        <TextBlock Text="资源详情"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="当前选中资源的详细信息"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,2,0,16" />

                        <TextBlock Text="标题"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding SelectedResource.Title, TargetNullValue=未选择资源}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />

                        <TextBlock Text="原文件名"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding SelectedResource.OriginalName, TargetNullValue=-}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />

                        <TextBlock Text="完整路径"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="{Binding SelectedResource.Path, TargetNullValue=-}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <Border Margin="0,10,0,0"
                                Padding="10,7"
                                Background="{DynamicResource MissingSurfaceBrush}"
                                BorderBrush="{DynamicResource MissingBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{Binding SelectedResource.IsMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="文件不存在或已移动。资源记录仍会保留。"
                                       Foreground="{DynamicResource MissingTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Border>

                        <TextBlock Text="基础信息"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <CheckBox Content="星标"
                                  IsChecked="{Binding SelectedResource.IsFavorite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Command="{Binding ToggleFavoriteCommand}"
                                  Foreground="{DynamicResource SecondaryTextBrush}"
                                  Margin="0,0,0,8" />
                        <TextBlock Text="{Binding SelectedResource.SizeBytes, Converter={StaticResource FileSizeDisplayConverter}, StringFormat=大小：{0}, TargetNullValue=大小：-}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding SelectedResource.ModifiedAt, StringFormat=修改时间：{0:yyyy-MM-dd HH:mm}, TargetNullValue=修改时间：-}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding SelectedResource.ImportedAt, StringFormat=导入时间：{0:yyyy-MM-dd HH:mm}, TargetNullValue=导入时间：-}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding SelectedResource.DurationMs, Converter={StaticResource DurationDisplayConverter}, StringFormat=时长：{0}, TargetNullValue=时长：-}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />

                        <TextBlock Text="集合"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding SelectedResourceCollections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="8,5"
                                            Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    Content="移出"
                                                    Command="{Binding DataContext.RemoveSelectedResourceFromCollectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,2"
                                                    Margin="8,0,0,0"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderStrongBrush}"
                                                    BorderThickness="1"
                                                    Foreground="{DynamicResource MutedTextBrush}" />
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="标签"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding SelectedResourceTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,6"
                                            Padding="8,4"
                                            Background="{Binding Color}"
                                            CornerRadius="12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TagTextBrush}" />
                                            <Button Content="×"
                                                    Command="{Binding DataContext.RemoveSelectedResourceTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="6,0,0,0"
                                                    Padding="4,0"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{DynamicResource TagTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="备注"
                                   Style="{StaticResource PanelTitleStyle}" />
                        <Border Padding="10"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBox Text="{Binding SelectedResource.Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="86"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                     CaretBrush="{DynamicResource AccentBrush}" />
                        </Border>
                        <Button Content="保存备注"
                                Command="{Binding SaveNoteCommand}"
                                Margin="0,8,0,0"
                                Padding="10,6"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderStrongBrush}"
                                BorderThickness="1"
                                Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Resources.Count, StringFormat=资源总数：{0}}"
                           VerticalAlignment="Center"
                           Style="{StaticResource MutedTextStyle}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedResourceCount, StringFormat=已选择：{0}}"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource MutedTextStyle}" />
                <StackPanel Grid.Column="2"
                            Margin="18,0,0,0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               VerticalAlignment="Center"
                               Style="{StaticResource MutedTextStyle}" />
                    <ProgressBar Width="120"
                                 Height="8"
                                 Margin="12,0,0,0"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 IsIndeterminate="{Binding IsScanning}" />
                </StackPanel>
                <TextBlock Grid.Column="3"
                           Text="作者：Phenol93"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</Window>
