<Window x:Class="LocalResourceExplorer.Views.AiSuggestionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 辅助整理"
        Width="820"
        Height="620"
        MinWidth="700"
        MinHeight="520"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border Margin="22"
            Padding="22"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="AI 辅助整理建议"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="勾选要应用的建议。取消关闭窗口不会写入任何修改。"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,4,0,14" />

                <Border Padding="12"
                        Background="{DynamicResource MissingSurfaceBrush}"
                        BorderBrush="{DynamicResource MissingBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Visibility="{Binding HasMissingItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding MissingItemsText}"
                                   Foreground="{DynamicResource MissingTextBrush}"
                                   TextWrapping="Wrap" />
                        <CheckBox Content="我确认创建上述不存在的集合或标签"
                                  IsChecked="{Binding ConfirmCreateMissingItems, Mode=TwoWay}"
                                  Foreground="{DynamicResource MissingTextBrush}"
                                  Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,14,0,0"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Suggestions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="14"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <CheckBox DockPanel.Dock="Right"
                                                  Content="应用此资源建议"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding Suggestion.ResourceName}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="15" />
                                    </DockPanel>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="138" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  Content="标题"
                                                  IsChecked="{Binding ApplyTitle, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsSelected}"
                                                  Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Suggestion.SuggestedTitle, TargetNullValue=-}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="138" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  Content="集合"
                                                  IsChecked="{Binding ApplyCollections, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsSelected}"
                                                  Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <StackPanel Grid.Column="1">
                                            <ItemsControl ItemsSource="{Binding CollectionNames}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,6"
                                                                Padding="8,3"
                                                                Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource BorderStrongBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="11">
                                                            <TextBlock Text="{Binding}"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       FontSize="12" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding MissingCollectionNames.Count, StringFormat=其中 {0} 个集合需要创建}"
                                                       Visibility="{Binding HasMissingCollections, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Foreground="{DynamicResource MissingTextBrush}"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="138" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  Content="标签"
                                                  IsChecked="{Binding ApplyTags, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsSelected}"
                                                  Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <StackPanel Grid.Column="1">
                                            <ItemsControl ItemsSource="{Binding TagNames}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,6"
                                                                Padding="8,3"
                                                                Background="{DynamicResource AiSurfaceBrush}"
                                                                BorderBrush="{DynamicResource AiBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="11">
                                                            <TextBlock Text="{Binding}"
                                                                       Foreground="{DynamicResource AiTextBrush}"
                                                                       FontSize="12" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding MissingTagNames.Count, StringFormat=其中 {0} 个标签需要创建}"
                                                       Visibility="{Binding HasMissingTags, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       Foreground="{DynamicResource MissingTextBrush}"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="138" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  Content="备注润色"
                                                  IsChecked="{Binding ApplyNote, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsSelected}"
                                                  Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Suggestion.SuggestedNote, TargetNullValue=-}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <TextBlock Text="原因"
                                               Style="{StaticResource LabelTextStyle}" />
                                    <TextBlock Text="{Binding Suggestion.Reason, TargetNullValue=-}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <DockPanel Grid.Row="2" Margin="0,16,0,0">
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="应用选中建议"
                            Command="{Binding ApplySelectedSuggestionsCommand}"
                            Style="{StaticResource DialogButtonStyle}" />
                    <Button Content="取消"
                            Click="CloseButton_Click"
                            Style="{StaticResource DialogButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
