<Window x:Class="LocalResourceExplorer.Views.CollectionCategoryPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择整理位置"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Border Padding="18"
            Background="{DynamicResource SurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="PromptTextBlock"
                       Text="请选择集合和二级分类"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14" />

            <StackPanel Grid.Row="1">
                <TextBlock Text="集合"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <ComboBox x:Name="CollectionComboBox"
                          DisplayMemberPath="Name"
                          SelectionChanged="CollectionComboBox_SelectionChanged"
                          MinHeight="32"
                          Margin="0,0,0,12" />

                <TextBlock Text="二级分类"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <ComboBox x:Name="CategoryComboBox"
                          DisplayMemberPath="Name"
                          MinHeight="32" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="取消"
                        IsCancel="True"
                        Padding="14,6"
                        Margin="0,0,8,0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderStrongBrush}"
                        Foreground="{DynamicResource SecondaryTextBrush}" />
                <Button Content="确定"
                        IsDefault="True"
                        Padding="14,6"
                        Click="OkButton_Click"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Foreground="White" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
