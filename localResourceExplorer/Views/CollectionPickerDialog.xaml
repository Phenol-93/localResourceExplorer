<Window x:Class="LocalResourceExplorer.Views.CollectionPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择集合"
        Width="380"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Border Padding="18"
            Background="{DynamicResource SurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="PromptTextBlock"
                       Text="请选择集合："
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />

            <ListBox x:Name="CollectionListBox"
                     Grid.Row="1"
                     DisplayMemberPath="Name"
                     BorderBrush="{DynamicResource BorderStrongBrush}"
                     Background="{DynamicResource SurfaceAltBrush}"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     MouseDoubleClick="CollectionListBox_MouseDoubleClick" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="取消"
                        IsCancel="True"
                        Padding="14,6"
                        Margin="0,0,8,0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderStrongBrush}"
                        Foreground="{DynamicResource SecondaryTextBrush}" />
                <Button Content="确定"
                        IsDefault="True"
                        Padding="14,6"
                        Click="OkButton_Click"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Foreground="White" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
