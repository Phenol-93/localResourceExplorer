<Window x:Class="LocalResourceExplorer.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="620"
        Height="520"
        MinWidth="560"
        MinHeight="460"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style x:Key="SettingsPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border Margin="22"
            Padding="22"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="设置"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="偏好、数据库位置与 AI 连接信息"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,4,0,14" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="主题"
                               Style="{StaticResource LabelTextStyle}" />
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              MinHeight="34"
                              Padding="8,5"
                              Background="{DynamicResource SurfaceAltBrush}"
                              BorderBrush="{DynamicResource BorderStrongBrush}"
                              Foreground="{DynamicResource SecondaryTextBrush}" />

                    <TextBlock Text="数据库位置"
                               Style="{StaticResource LabelTextStyle}" />
                    <TextBox Text="{Binding DatabasePath}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Style="{StaticResource SettingsTextBoxStyle}" />

                    <TextBlock Text="AI Base URL"
                               Style="{StaticResource LabelTextStyle}" />
                    <TextBox Text="{Binding AiBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsTextBoxStyle}" />

                    <TextBlock Text="AI API Key"
                               Style="{StaticResource LabelTextStyle}" />
                    <PasswordBox x:Name="ApiKeyPasswordBox"
                                 PasswordChanged="ApiKeyPasswordBox_PasswordChanged"
                                 Style="{StaticResource SettingsPasswordBoxStyle}" />

                    <TextBlock Text="AI 模型名称"
                               Style="{StaticResource LabelTextStyle}" />
                    <TextBox Text="{Binding AiModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SettingsTextBoxStyle}" />

                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource BodyTextStyle}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,16,0,0" />
                </StackPanel>
            </ScrollViewer>

            <DockPanel Grid.Row="2"
                       Margin="0,18,0,0"
                       LastChildFill="False">
                <Button Content="清除 API Key"
                        Command="{Binding ClearApiKeyCommand}"
                        Style="{StaticResource SettingsButtonStyle}"
                        DockPanel.Dock="Left"
                        Margin="0,0,8,0" />
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="测试 AI 连接"
                            Command="{Binding TestAiConnectionCommand}"
                            Style="{StaticResource SettingsButtonStyle}" />
                    <Button Content="保存"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource SettingsButtonStyle}" />
                    <Button Content="关闭"
                            Click="CloseButton_Click"
                            Style="{StaticResource SettingsButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
