<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#F6F7F9</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#F8FAFC</Color>
    <Color x:Key="SidebarColor">#F1F5F9</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <Color x:Key="BorderStrongColor">#CBD5E1</Color>
    <Color x:Key="PrimaryTextColor">#172033</Color>
    <Color x:Key="SecondaryTextColor">#243042</Color>
    <Color x:Key="MutedTextColor">#64748B</Color>
    <Color x:Key="NavSelectedColor">#E2E8F0</Color>
    <Color x:Key="NavHoverColor">#E8EEF6</Color>
    <Color x:Key="ListHoverColor">#F1F5F9</Color>
    <Color x:Key="ListSelectedColor">#E8F1FF</Color>
    <Color x:Key="ListSelectedBorderColor">#BFD8FF</Color>
    <Color x:Key="MissingSurfaceColor">#FFF7ED</Color>
    <Color x:Key="MissingBorderColor">#FDBA74</Color>
    <Color x:Key="MissingTextColor">#9A3412</Color>
    <Color x:Key="AccentColor">#2563EB</Color>
    <Color x:Key="AiSurfaceColor">#EEF6FF</Color>
    <Color x:Key="AiBorderColor">#BFD8FF</Color>
    <Color x:Key="AiTextColor">#1D4ED8</Color>
    <Color x:Key="TagTextColor">#243042</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="NavSelectedBrush" Color="{StaticResource NavSelectedColor}" />
    <SolidColorBrush x:Key="NavHoverBrush" Color="{StaticResource NavHoverColor}" />
    <SolidColorBrush x:Key="ListHoverBrush" Color="{StaticResource ListHoverColor}" />
    <SolidColorBrush x:Key="ListSelectedBrush" Color="{StaticResource ListSelectedColor}" />
    <SolidColorBrush x:Key="ListSelectedBorderBrush" Color="{StaticResource ListSelectedBorderColor}" />
    <SolidColorBrush x:Key="MissingSurfaceBrush" Color="{StaticResource MissingSurfaceColor}" />
    <SolidColorBrush x:Key="MissingBorderBrush" Color="{StaticResource MissingBorderColor}" />
    <SolidColorBrush x:Key="MissingTextBrush" Color="{StaticResource MissingTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AiSurfaceBrush" Color="{StaticResource AiSurfaceColor}" />
    <SolidColorBrush x:Key="AiBorderBrush" Color="{StaticResource AiBorderColor}" />
    <SolidColorBrush x:Key="AiTextBrush" Color="{StaticResource AiTextColor}" />
    <SolidColorBrush x:Key="TagTextBrush" Color="{StaticResource TagTextColor}" />
</ResourceDictionary>
